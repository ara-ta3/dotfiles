autoload -Uz vcs_info
autoload -U colors && colors

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:*' max-exports 6 # formatに入る変数の最大数
zstyle ':vcs_info:git:*' check-for-changes true
zstyle ':vcs_info:git:*' formats '%b'

function set_tab_title() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  repo=$(basename -s .git $(git remote get-url origin 2>/dev/null) 2>/dev/null)
  if [[ -n "$branch" ]]; then
    print -Pn "\e]1;$branch@$repo\a"
  else
    print -Pn "\e]1;%2~\a"
  fi
}
precmd_functions+=(set_tab_title)
precmd () {
    psvar=()
    LANG=ja_JP.UTF-8 vcs_info
    [[ -n "$vcs_info_msg_0_" ]] && psvar[1]="$vcs_info_msg_0_"
    psvar[2]=$(get_uptime);
}

function get_uptime() {
    local u res
    u=$(uptime)
    echo $u | grep min > /dev/null 2> /dev/null
    if [ $? -eq 0 ]; then
        echo $u|awk '{print $3 " " $4}'|tr -d ,
        return
    fi
    echo $u | grep days > /dev/null 2> /dev/null
    if [ $? -eq 0 ]; then
        echo $u|awk '{print $3 " " $4}'|tr -d ,
        return
    fi
    echo $u | grep hrs > /dev/null 2> /dev/null
    if [ $? -eq 0 ]; then
        echo $u|awk '{print $3 " " $4}'|tr -d ,
        return
    fi

    echo $u|awk '{print $3}'|tr -d ,
}


function left-prompt {
    local FIRST='178m%}'
    local FIRST_B='237m%}'
    local SECOND='007m%}'
    local SECOND_B='067m%}'

    local sharp='\uE0B0'
    local FG='%{[38;5;'
    local BG='%{[30;48;5;'
    local RESET='%{[0m%}'
    local USER_AND_HOST="${BG}${FIRST_B}${FG}${FIRST}"
    local DIR="${BG}${SECOND_B}${FG}${SECOND}"
    # @see precmd
    echo "${USER_AND_HOST}%n@%m(Up %2v) ${DIR}%~${RESET}"
}

function git-prompt {
    echo "%1v"
}

gitprompt="$(git-prompt)"
above="$(left-prompt)"

PROMPT="$above
%(?.%{$fg[blue]%}.%{$fg[red]%})%(?!( ｡◕‿◕｡) <!( *;-;%)? <)%{${reset_color}%} "

RPROMPT=$gitprompt

SPROMPT="%{$fg[magenta]%}%{$suggest%}( *◕~◕%)? < もしかして%{$fg[red]%} %B%r%b ${reset_color}%{$fg[magenta]%}かな? [そう!(%{$fg[blue]%}y${reset_color}%{$fg[magenta]%}), 違う!(%{$fg[red]%}n${reset_color}%{$fg[magenta]%}),a,e]: ${reset_color}"


